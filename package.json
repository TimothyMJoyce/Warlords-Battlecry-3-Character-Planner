{
  "name": "wbc3-character-planner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A verified Warlords Battlecry III character build planner.",
  "scripts": {
    "dev": "node tools/server.mjs",
    "desktop": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\tools\\start-desktop.ps1",
    "desktop:refresh": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\tools\\start-desktop.ps1 -RefreshLocalData",
    "desktop:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\tools\\start-desktop.ps1 -Stop",
    "build:desktop": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\tools\\build-desktop-exe.ps1",
    "import:heroes": "node tools/import-hero-data.mjs",
    "extract:portraits": "node tools/extract-portraits.mjs",
    "extract:icons": "node tools/extract-ui-icons.mjs",
    "test": "node tools/test.mjs",
    "build": "node tools/build.mjs"
  }
}
